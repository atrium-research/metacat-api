# Datasource backend: json (default), or sparql
DATASOURCE_KIND=json

# Path read by the json datasource (metacat-data JSON snapshots)
JSON_DATA_DIR=./data

# SPARQL endpoint used by the sparql datasource (future EOSC EU Node GraphDB)
SPARQL_ENDPOINT=

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: json (production) or console (development)
LOG_FORMAT=console
